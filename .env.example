# === Mode ===
# true = single-user (current behavior, no auth needed)
# false = multi-user (public instance, requires SERVER_SECRET)
SINGLE_USER_MODE=true

# === Required for SINGLE_USER_MODE ===
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# === Required for multi-user mode ===
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# SERVER_SECRET=

# === Limits (multi-user mode) ===
# MAX_USER_CONTEXTS=50
# MAX_CONCURRENT_JOBS=10
# MAX_MESSAGES_PER_JOB=50000
# SESSION_EXPIRY_DAYS=7
# MAX_SESSIONS_PER_USER=3

# === Logging ===
# LOG_LEVEL=INFO
# LOG_FILE=  (leave empty for stdout-only, recommended for Docker)

# === Paths (usually no need to change) ===
# SESSION_DIR=./sessions
# DB_PATH=./data.db

# === Production (docker-compose.prod.yml) ===
# DOMAIN=yourdomain.com
